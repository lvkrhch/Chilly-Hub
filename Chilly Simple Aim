trackConnection(UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if isDestroyed then
        return
    end

    if not gameProcessed
        and (input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch) then
        isMouseDown = true
    end

    if input.KeyCode == settings.menuKey and screenGui then
        screenGui.Enabled = not screenGui.Enabled
        return
    end

    if gameProcessed then
        return
    end

    if input.KeyCode == settings.aimToggleKey then
        settings.enabled = not settings.enabled

        if settings.enabled and not currentTarget then
            setCurrentTarget(getBestTarget())
        elseif not settings.enabled then
            setCurrentTarget(nil)
        end

        if refreshUi then
            refreshUi()
        end
        return
    end

    if input.KeyCode == settings.targetSwitchKey then
        cycleTarget()
        if refreshUi then
            refreshUi()
        end
    end
end))

trackConnection(UserInputService.InputEnded:Connect(function(input)
    if isDestroyed then
        return
    end

    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        isMouseDown = false
    end
end))

trackConnection(UserInputService.JumpRequest:Connect(function()
    if isDestroyed then
        return
    end

    if not settings.infiniteJumpEnabled then
        return
    end

    local humanoid = getLocalHumanoid()
    if humanoid then
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end))

trackConnection(Players.PlayerRemoving:Connect(function(player)
    if isDestroyed then
        return
    end

    destroyEsp(player)
    destroyHitbox(player)

    if currentTarget == player then
        setCurrentTarget(nil)
    end

    if selectedTeleportPlayer == player then
        selectedTeleportPlayer = nil
    end

    if playerCharacterConnections[player] then
        playerCharacterConnections[player]:Disconnect()
        playerCharacterConnections[player] = nil
    end
end))

trackConnection(Players.PlayerAdded:Connect(function(player)
    if isDestroyed then
        return
    end

    playerCharacterConnections[player] = player.CharacterAdded:Connect(function()
        if isDestroyed then
            return
        end

        task.wait(0.25)
        if refreshUi and not isDestroyed then
            refreshUi()
        end
    end)
end))

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= localPlayer then
        playerCharacterConnections[player] = player.CharacterAdded:Connect(function()
            if isDestroyed then
                return
            end

            task.wait(0.25)
            if refreshUi and not isDestroyed then
                refreshUi()
            end
        end)
    end
end

trackConnection(localPlayer.CharacterAdded:Connect(function()
    if isDestroyed then
        return
    end

    task.wait(0.2)
    originalCollisions = {}
    baseMovementSettings = nil
    animationHookedCharacter = nil
    captureBaseMovementSettings(true)
    hookWeaponAnimations(getCharacter(localPlayer))
    applyMovementSettings()
end))

RunService:BindToRenderStep(renderStepName, Enum.RenderPriority.Camera.Value + 1, function(deltaTime)
    if isDestroyed then
        return
    end

    camera = workspace.CurrentCamera

    refreshEsp()
    refreshHitboxes()
    applyMovementSettings()
    applyNoclip()
    applyFly(deltaTime)
    tryFastFire()
    stopBlockedWeaponAnimations()

    if not camera or not settings.enabled then
        return
    end

    if settings.retargetEveryFrame or not currentTarget or not isValidTarget(currentTarget) then
        setCurrentTarget(getBestTarget())
    end

    if currentTarget then
        local character = getCharacter(currentTarget)
        local humanoid = getHumanoid(character)
        local targetPart = getAimPart(character)

        if not humanoid or humanoid.Health <= 0 or humanoid:GetState() == Enum.HumanoidStateType.Dead then
            setCurrentTarget(nil)
            return
        end

        if targetPart and hasLineOfSight(character, targetPart) then
            aimAt(targetPart, deltaTime)
            tryAutoShoot()
        else
            setCurrentTarget(nil)
        end
    end
end)

captureBaseMovementSettings(true)
hookWeaponAnimations(getCharacter(localPlayer))
createUi()
