end

local function addTeamToken(tokens, sourceName, value)
    if value == nil then
        return
    end

    local text = tostring(value)
    if text == "" then
        return
    end

    tokens[sourceName .. ":" .. text] = true
end

local function isIgnoredTeamText(value)
    local text = string.lower(tostring(value or ""))

    return text == ""
        or text == "none"
        or text == "nil"
        or text == "neutral"
        or text == "ffa"
        or text == "freeforall"
        or text == "free for all"
        or text == "playing"
        or text == "player"
        or text == "players"
        or text == "lobby"
        or text == "spectator"
        or text == "spectators"
end

local function readTeamValueObject(parent, tokens)
    if not parent then
        return
    end

    for _, name in ipairs(customTeamAttributes) do
        local child = parent:FindFirstChild(name)

        if child and child:IsA("ValueBase") then
            if not isIgnoredTeamText(child.Value) then
                addTeamToken(tokens, "Value:" .. name, child.Value)
            end
        end
    end
end

local function getTeamTokens(player)
    local tokens = {}
    local character = getCharacter(player)

    if player.Team and not player.Neutral and not isIgnoredTeamText(player.Team.Name) then
        addTeamToken(tokens, "Team", player.Team.Name)
        addTeamToken(tokens, "TeamColor", player.TeamColor.Name)
    elseif not player.Neutral and not isIgnoredTeamText(player.TeamColor.Name) then
        addTeamToken(tokens, "TeamColor", player.TeamColor.Name)
    end

    for _, attributeName in ipairs(customTeamAttributes) do
        local playerValue = player:GetAttribute(attributeName)
        if not isIgnoredTeamText(playerValue) then
            addTeamToken(tokens, "Attribute:" .. attributeName, playerValue)
        end

        if character then
            local characterValue = character:GetAttribute(attributeName)
            if not isIgnoredTeamText(characterValue) then
                addTeamToken(tokens, "CharacterAttribute:" .. attributeName, characterValue)
            end
        end
    end

    readTeamValueObject(player, tokens)
    readTeamValueObject(character, tokens)

    return tokens
end

local function getTeamValue(player)
    local tokens = getTeamTokens(player)

    for token in pairs(tokens) do
        return token
    end

    return nil
end

local function hasAnyToken(tokens)
    return next(tokens) ~= nil
end

local function teamTokensOverlap(firstTokens, secondTokens)
    for token in pairs(firstTokens) do
        if secondTokens[token] then
            return true
        end
    end

    return false
end

local function hasMatchingTeam(player)
    local myTokens = getTeamTokens(localPlayer)
    local theirTokens = getTeamTokens(player)

    if not hasAnyToken(myTokens) or not hasAnyToken(theirTokens) then
        return false
    end

    for token in pairs(myTokens) do
        if theirTokens[token] then
            return true
        end
    end

    return false
end

local function isTeamMatch()
    local teamGroups = {}

    for _, player in ipairs(Players:GetPlayers()) do
        local tokens = getTeamTokens(player)

        if hasAnyToken(tokens) then
            local matchedGroup = false

            for _, groupTokens in ipairs(teamGroups) do
                if teamTokensOverlap(tokens, groupTokens) then
                    for token in pairs(tokens) do
                        groupTokens[token] = true
                    end

                    matchedGroup = true
                    break
                end
            end

            if not matchedGroup then
                table.insert(teamGroups, tokens)
            end
        end

        if #teamGroups >= 2 then
            return true
        end
    end

    return false
end

local function isSameTeam(player)
    if not isTeamMatch() then
        return false
    end

    return hasMatchingTeam(player)
end

local function hasLineOfSight(targetCharacter, targetPart)
    if not settings.wallCheck then
        return true
    end

    camera = workspace.CurrentCamera
    if not camera or not targetPart then
        return false
    end

    local origin = camera.CFrame.Position
    local direction = targetPart.Position - origin

    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {getCharacter(localPlayer)}
    raycastParams.IgnoreWater = true

    local result = workspace:Raycast(origin, direction, raycastParams)

    if not result then
        return true
    end

    return result.Instance:IsDescendantOf(targetCharacter)
end

local function isAlive(player)
    local character = getCharacter(player)
    local humanoid = getHumanoid(character)

    return character ~= nil
        and humanoid ~= nil
        and humanoid.Health > 0
        and humanoid:GetState() ~= Enum.HumanoidStateType.Dead
end

local function isValidTarget(player)
    if player == localPlayer then
        return false
    end

    if isSameTeam(player) then
        return false
    end

    local character = getCharacter(player)
    local aimPart = getAimPart(character)

    if not isAlive(player) or not aimPart then
        return false
    end

    return hasLineOfSight(character, aimPart)
end

local function disconnectTargetSignals()
    if targetDiedConnection then
        targetDiedConnection:Disconnect()
        targetDiedConnection = nil
    end

    if targetCharacterRemovingConnection then
        targetCharacterRemovingConnection:Disconnect()
        targetCharacterRemovingConnection = nil
    end
end

local function setCurrentTarget(player)
    if currentTarget == player then
        return
    end

    disconnectTargetSignals()
    currentTarget = player

    if not currentTarget then
        if refreshUi then
            refreshUi()
        end
        return
    end

    local character = getCharacter(currentTarget)
    local humanoid = getHumanoid(character)

    if humanoid then
        targetDiedConnection = humanoid.Died:Connect(function()
            setCurrentTarget(nil)
        end)
    end

    targetCharacterRemovingConnection = currentTarget.CharacterRemoving:Connect(function()
        setCurrentTarget(nil)
    end)

    if refreshUi then
        refreshUi()
    end
end

local function getScreenDistanceFromCenter(worldPosition)
    camera = workspace.CurrentCamera
    if not camera then
        return math.huge
    end

    local viewportPoint, onScreen = camera:WorldToViewportPoint(worldPosition)
    if not onScreen or viewportPoint.Z <= 0 then
        return math.huge
    end

    local viewportSize = camera.ViewportSize
    local screenCenter = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    local point = Vector2.new(viewportPoint.X, viewportPoint.Y)

    return (point - screenCenter).Magnitude
end

local function getWorldDistanceFromLocalPlayer(worldPosition)
    local root = getLocalRootPart()
    if not root then
        return math.huge
    end

    return (root.Position - worldPosition).Magnitude
end

local function getTargetScore(player)
    local character = getCharacter(player)
    local aimPart = getAimPart(character)

    if not aimPart then
        return math.huge
    end

    if settings.targetMode == "Distance" then
        return getWorldDistanceFromLocalPlayer(aimPart.Position)
    end

    local screenDistance = getScreenDistanceFromCenter(aimPart.Position)
    if screenDistance > settings.fovRadius then
        return math.huge
    end

    return screenDistance
end

local function getSortedTargets()
    local targets = {}

    for _, player in ipairs(Players:GetPlayers()) do
        if isValidTarget(player) then
            local score = getTargetScore(player)

            if score < math.huge then
                table.insert(targets, {
                    player = player,
                    score = score,
                })
            end
        end
    end

    table.sort(targets, function(a, b)
        return a.score < b.score
    end)

    return targets
end

local function getBestTarget()
    local targets = getSortedTargets()
    return targets[1] and targets[1].player or nil
end

local function cycleTarget()
    local targets = getSortedTargets()

    if #targets == 0 then
        setCurrentTarget(nil)
        return
    end

    if not settings.enabled then
        settings.enabled = true
    end

    local currentIndex = nil
    for index, entry in ipairs(targets) do
        if entry.player == currentTarget then
            currentIndex = index
            break
        end
    end

    local nextIndex = currentIndex and currentIndex + 1 or 1
    if nextIndex > #targets then
        nextIndex = 1
    end

    setCurrentTarget(targets[nextIndex].player)
end

local function aimAt(targetPart, deltaTime)
    camera = workspace.CurrentCamera

    if not camera or not targetPart then
        return
    end

    local cameraPosition = camera.CFrame.Position
    local targetCFrame = CFrame.lookAt(cameraPosition, targetPart.Position)
    local frameScale = math.max(deltaTime or 1 / 60, 1 / 240) * 60
    local alpha = 1 - math.pow(math.clamp(settings.smoothness, 0.05, 0.98), frameScale)

    camera.CFrame = camera.CFrame:Lerp(targetCFrame, math.clamp(alpha, 0.02, 0.95))
end

local function getEquippedTool()
    local character = getCharacter(localPlayer)
    if not character then
        return nil
    end

    return character:FindFirstChildOfClass("Tool")
end

local function tryAutoShoot()
    if not settings.autoShoot then
        return
    end

    local now = os.clock()
    if now - lastShotTime < settings.shootCooldown then
        return
    end

    local tool = getEquippedTool()
    if not tool then
        return
    end

    lastShotTime = now
    tool:Activate()
end

local function tryFastFire()
    if not settings.fastFire or not isMouseDown then
        return
    end

    local now = os.clock()
    if now - lastFastFireTime < settings.fastFireInterval then
        return
    end

    local tool = getEquippedTool()
    if not tool then
        return
    end

    lastFastFireTime = now
    tool:Activate()
end

local function shouldBlockWeaponAnimation(track)
    local trackName = string.lower(track.Name or "")
    local animationName = ""
    local animationId = ""

    pcall(function()
        if track.Animation then
            animationName = string.lower(track.Animation.Name or "")
            animationId = string.lower(track.Animation.AnimationId or "")
        end
    end)

    for _, keyword in ipairs(blockedWeaponAnimationKeywords) do
        if string.find(trackName, keyword, 1, true)
            or string.find(animationName, keyword, 1, true)
            or string.find(animationId, keyword, 1, true) then
            return true
        end
    end

    return false
end

local function stopBlockedWeaponAnimations()
    if not settings.noBoltAnimation then
        return
    end

    local humanoid = getLocalHumanoid()
    local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")

    if not animator then
        return
    end

    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        if shouldBlockWeaponAnimation(track) then
            track:Stop(0)
        end
    end
end

local function hookWeaponAnimations(character)
    if not character or animationHookedCharacter == character then
        return
    end

    local humanoid = getHumanoid(character)
    if not humanoid then
        return
    end

    local animator = humanoid:FindFirstChildOfClass("Animator")
        or humanoid:WaitForChild("Animator", 3)

    if not animator then
        return
    end

    animationHookedCharacter = character

    trackConnection(animator.AnimationPlayed:Connect(function(track)
        if isDestroyed or not settings.noBoltAnimation then
            return
        end

        if shouldBlockWeaponAnimation(track) then
            task.defer(function()
                if track.IsPlaying then
                    track:Stop(0)
                end
            end)
        end
    end))
end

local function captureBaseMovementSettings(force)
    local humanoid = getLocalHumanoid()
    if not humanoid then
        return
    end

    if baseMovementSettings and not force then
        return
    end

    local useJumpPower = true
    pcall(function()
        useJumpPower = humanoid.UseJumpPower
    end)

    baseMovementSettings = {
        walkSpeed = humanoid.WalkSpeed,
        jumpPower = humanoid.JumpPower,
        jumpHeight = humanoid.JumpHeight,
        useJumpPower = useJumpPower,
    }

    settings.walkSpeed = baseMovementSettings.walkSpeed
    settings.jumpPower = baseMovementSettings.jumpPower
    settings.jumpHeight = baseMovementSettings.jumpHeight
    settings.useJumpPower = baseMovementSettings.useJumpPower
    settings.maxWalkSpeed = math.max(settings.maxWalkSpeed, baseMovementSettings.walkSpeed * 3)
    settings.maxJumpPower = math.max(settings.maxJumpPower, baseMovementSettings.jumpPower * 3)
end

local function applyMovementSettings()
    local humanoid = getLocalHumanoid()
    if not humanoid then
        return
    end

    captureBaseMovementSettings(false)
    humanoid.WalkSpeed = settings.walkSpeed

    pcall(function()
        humanoid.UseJumpPower = settings.useJumpPower
    end)

    if settings.useJumpPower then
        humanoid.JumpPower = settings.jumpPower
    else
        humanoid.JumpHeight = settings.jumpHeight
    end
end

local function adjustWalkSpeed(amount)
    settings.walkSpeed = math.clamp(
        settings.walkSpeed + amount,
        settings.minWalkSpeed,
        settings.maxWalkSpeed
    )

    applyMovementSettings()
end

local function adjustJumpPower(amount)
    if settings.useJumpPower then
        settings.jumpPower = math.clamp(
            settings.jumpPower + amount,
            settings.minJumpPower,
            settings.maxJumpPower
        )
    else
        settings.jumpHeight = math.clamp(
            settings.jumpHeight + amount / 10,
            3,
            25
        )
    end

    applyMovementSettings()
end

local function resetMovementToGameDefaults()
    captureBaseMovementSettings(false)

    if not baseMovementSettings then
        return
    end

    settings.walkSpeed = baseMovementSettings.walkSpeed
    settings.jumpPower = baseMovementSettings.jumpPower
    settings.jumpHeight = baseMovementSettings.jumpHeight
    settings.useJumpPower = baseMovementSettings.useJumpPower
    applyMovementSettings()
end

local function adjustFlySpeed(amount)
    settings.flySpeed = math.clamp(
        settings.flySpeed + amount,
        settings.minFlySpeed,
        settings.maxFlySpeed
    )
end

local function adjustHitboxSize(amount)
    settings.hitboxSize = math.clamp(
        settings.hitboxSize + amount,
        settings.minHitboxSize,
        settings.maxHitboxSize
    )
end

local function cycleHitboxShape()
    settings.hitboxShape = settings.hitboxShape == "Box" and "Ball" or "Box"
end

local function cycleHitboxTargetMode()
    if settings.hitboxTargetMode == "Enemies" then
        settings.hitboxTargetMode = "Target"
    elseif settings.hitboxTargetMode == "Target" then
        settings.hitboxTargetMode = "All"
    else
        settings.hitboxTargetMode = "Enemies"
    end

end

local function getNextKey(currentKey)
    local currentIndex = table.find(keyChoices, currentKey) or 1
    local nextIndex = currentIndex + 1

    if nextIndex > #keyChoices then
        nextIndex = 1
    end

    return keyChoices[nextIndex]
end

local function destroyEsp(player)
    local highlight = espHighlights[player]
    if highlight then
        highlight:Destroy()
        espHighlights[player] = nil
    end

    local box = espBoxes[player]
    if box then
        box:Destroy()
        espBoxes[player] = nil
    end

    local billboard = espBillboards[player]
    if billboard then
        billboard:Destroy()
        espBillboards[player] = nil
    end
end

local function shouldShowEsp(player)
    if player == localPlayer then
        return false
    end

    if not settings.espCharm and not settings.espBox and not settings.espHealth then
        return false
    end

    return isAlive(player)
end

local function updateEspForPlayer(player)
    if not shouldShowEsp(player) then
        destroyEsp(player)
        return
    end

    local character = getCharacter(player)
    local humanoid = getHumanoid(character)
    local root = getRootPart(character)

    if not character or not humanoid or not root then
        destroyEsp(player)
        return
    end

    local isFriendly = isTeamMatch() and hasMatchingTeam(player)
    local mainColor = isFriendly and Color3.fromRGB(55, 145, 255) or Color3.fromRGB(255, 75, 60)
    local accentColor = isFriendly and Color3.fromRGB(175, 220, 255) or Color3.fromRGB(255, 220, 120)

    if settings.espCharm then
        local highlight = espHighlights[player]

        if not highlight or highlight.Parent ~= character then
            if highlight then
                highlight:Destroy()
            end

            highlight = Instance.new("Highlight")
            highlight.Name = "ChillyEspCharm"
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.FillTransparency = 0.6
            highlight.OutlineTransparency = 0.15
            highlight.Adornee = character
            highlight.Parent = character

            espHighlights[player] = highlight
        end

        highlight.FillColor = mainColor
        highlight.OutlineColor = accentColor
    elseif espHighlights[player] then
        espHighlights[player]:Destroy()
        espHighlights[player] = nil
    end

    if settings.espBox then
        local box = espBoxes[player]

        if not box or box.Parent ~= root then
            if box then
                box:Destroy()
            end

            box = Instance.new("BoxHandleAdornment")
            box.Name = "ChillyEspBox"
            box.AlwaysOnTop = true
            box.Adornee = root
            box.ZIndex = 4
            box.Transparency = 0.45
            box.Size = Vector3.new(4, 6, 2.5)
            box.Parent = root

            espBoxes[player] = box
        end

        box.Color3 = mainColor
    elseif espBoxes[player] then
        espBoxes[player]:Destroy()
        espBoxes[player] = nil
    end

    if settings.espHealth then
        local billboard = espBillboards[player]

        if not billboard or billboard.Parent ~= root then
            if billboard then
                billboard:Destroy()
            end

            billboard = Instance.new("BillboardGui")
            billboard.Name = "ChillyEspHealth"
            billboard.AlwaysOnTop = true
            billboard.Size = UDim2.fromOffset(86, 34)
            billboard.StudsOffset = Vector3.new(0, 3.6, 0)
            billboard.Adornee = root
            billboard.Parent = root

            local label = Instance.new("TextLabel")
            label.Name = "NameLabel"
            label.Size = UDim2.new(1, 0, 0, 16)
            label.BackgroundTransparency = 1
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            label.TextStrokeTransparency = 0.35
            label.Font = Enum.Font.GothamBold
            label.TextSize = 11
            label.Parent = billboard

            local barBack = Instance.new("Frame")
            barBack.Name = "BarBack"
            barBack.Size = UDim2.new(1, -12, 0, 6)
            barBack.Position = UDim2.fromOffset(6, 21)
            barBack.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            barBack.BorderSizePixel = 0
            barBack.Parent = billboard

            local bar = Instance.new("Frame")
            bar.Name = "Bar"
            bar.Size = UDim2.new(1, 0, 1, 0)
            bar.BackgroundColor3 = Color3.fromRGB(70, 215, 105)
            bar.BorderSizePixel = 0
            bar.Parent = barBack

            espBillboards[player] = billboard
        end

        local label = billboard:FindFirstChild("NameLabel")
        local barBack = billboard:FindFirstChild("BarBack")
        local bar = barBack and barBack:FindFirstChild("Bar")
        local ratio = humanoid.MaxHealth > 0 and math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1) or 0

        if label then
            label.Text = player.Name .. " " .. tostring(math.floor(humanoid.Health))
        end

        if bar then
            bar.Size = UDim2.new(ratio, 0, 1, 0)
            bar.BackgroundColor3 = Color3.fromRGB(220 - 150 * ratio, 65 + 150 * ratio, 70)
        end
    elseif espBillboards[player] then
        espBillboards[player]:Destroy()
        espBillboards[player] = nil
    end
end

local function refreshEsp()
    for _, player in ipairs(Players:GetPlayers()) do
        updateEspForPlayer(player)
    end
end

local function destroyHitbox(player)
    local part = hitboxParts[player]

    if part then
        part:Destroy()
        hitboxParts[player] = nil
    end
end

local function isValidHitboxTarget(player)
    if player == localPlayer then
        return false
    end

    if not isAlive(player) then
        return false
    end

    if settings.hitboxTargetMode == "Enemies" or settings.hitboxTargetMode == "Target" then
        return not isSameTeam(player)
    end

    return true
end

local function getBestHitboxTarget()
    local bestPlayer = nil
    local bestDistance = math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if isValidHitboxTarget(player) then
            local root = getRootPart(getCharacter(player))

            if root then
                local distance = getWorldDistanceFromLocalPlayer(root.Position)

                if distance < bestDistance then
                    bestDistance = distance
                    bestPlayer = player
                end
            end
        end
    end

    return bestPlayer
end

local function shouldExpandHitboxForPlayer(player)
    if not settings.hitboxExpander or not isValidHitboxTarget(player) then
        return false
    end

    if settings.hitboxTargetMode == "Target" then
        return player == (currentTarget or getBestHitboxTarget())
    end

    if settings.hitboxTargetMode == "Enemies" then
        return true
    end

    return true
end

local function getHitboxSize()
    if settings.hitboxShape == "Box" then
        return Vector3.new(settings.hitboxSize * 0.75, settings.hitboxSize, settings.hitboxSize * 0.5)
    end

    return Vector3.new(settings.hitboxSize, settings.hitboxSize, settings.hitboxSize)
end

local function getHitboxColor(player)
    if player == currentTarget then
        return Color3.fromRGB(255, 215, 80)
    end

    if isSameTeam(player) then
        return Color3.fromRGB(55, 145, 255)
    end

    return Color3.fromRGB(255, 80, 80)
end

local function updateHitboxForPlayer(player)
    if not shouldExpandHitboxForPlayer(player) then
        destroyHitbox(player)
        return
    end

    local character = getCharacter(player)
    local root = getRootPart(character)

    if not character or not root then
        destroyHitbox(player)
        return
    end

    local hitbox = hitboxParts[player]
    if not hitbox or hitbox.Parent ~= character then
        destroyHitbox(player)

        hitbox = Instance.new("Part")
        hitbox.Name = "ChillyHitboxExpander"
        hitbox.Material = Enum.Material.ForceField
        hitbox.Transparency = settings.hitboxTransparency
        hitbox.CanCollide = false
        hitbox.CanTouch = false
        hitbox.CanQuery = true
        hitbox.Massless = true
        hitbox.Anchored = false
        hitbox.CFrame = root.CFrame
        hitbox:SetAttribute("ChillyHitboxIgnoresWallCheck", true)
        hitbox:SetAttribute("ChillyHitboxOwnerUserId", player.UserId)
        hitbox:SetAttribute("ChillyHitboxTargetMode", settings.hitboxTargetMode)
        hitbox.Parent = character

        local weld = Instance.new("WeldConstraint")
        weld.Part0 = hitbox
        weld.Part1 = root
        weld.Parent = hitbox

        hitboxParts[player] = hitbox
    end

    hitbox.Shape = settings.hitboxShape == "Ball" and Enum.PartType.Ball or Enum.PartType.Block
    hitbox.Size = getHitboxSize()
    hitbox.Color = getHitboxColor(player)
    hitbox.Transparency = settings.hitboxTransparency
    hitbox:SetAttribute("ChillyHitboxTargetMode", settings.hitboxTargetMode)
    hitbox.CFrame = root.CFrame
end

local function refreshHitboxes()
    for _, player in ipairs(Players:GetPlayers()) do
        updateHitboxForPlayer(player)
    end
end

local function clearHitboxes()
    for player in pairs(hitboxParts) do
        destroyHitbox(player)
    end
end

local function applyNoclip()
    local character = getCharacter(localPlayer)
    if not character then
        return
    end

    if settings.noclipEnabled then
        for _, descendant in ipairs(character:GetDescendants()) do
            if descendant:IsA("BasePart") then
                if originalCollisions[descendant] == nil then
                    originalCollisions[descendant] = descendant.CanCollide
                end

                descendant.CanCollide = false
            end
        end
        return
    end

    for part, canCollide in pairs(originalCollisions) do
        if part and part.Parent then
            part.CanCollide = canCollide
        end
        originalCollisions[part] = nil
    end
end

local function applyFly(deltaTime)
    local character = getCharacter(localPlayer)
    local humanoid = getHumanoid(character)
    local root = getRootPart(character)

    if not character or not humanoid or not root then
        return
    end

    if not settings.flyEnabled then
        humanoid.PlatformStand = false
        return
    end

    camera = workspace.CurrentCamera
    if not camera then
        return
    end

    local moveDirection = Vector3.new(0, 0, 0)

    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        moveDirection = moveDirection + camera.CFrame.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        moveDirection = moveDirection - camera.CFrame.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
        moveDirection = moveDirection + camera.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
        moveDirection = moveDirection - camera.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        moveDirection = moveDirection + Vector3.new(0, 1, 0)
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        moveDirection = moveDirection - Vector3.new(0, 1, 0)
    end

    if moveDirection.Magnitude > 0 then
        moveDirection = moveDirection.Unit
    end

    humanoid.PlatformStand = true
    local targetVelocity = moveDirection * settings.flySpeed
    local alpha = math.clamp((deltaTime or 1 / 60) * 12, 0.05, 0.6)
    root.AssemblyLinearVelocity = root.AssemblyLinearVelocity:Lerp(targetVelocity, alpha)
    root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
end

local function teleportToPlayer(player)
    if not player or player == localPlayer then
        return
    end

    local localRoot = getLocalRootPart()
    local targetRoot = getRootPart(getCharacter(player))

    if not localRoot or not targetRoot then
        return
    end

    localRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 4)
    localRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end

local function getTeleportPlayers()
    local list = {}

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= localPlayer and getCharacter(player) then
            table.insert(list, player)
        end
    end

    table.sort(list, function(a, b)
        return a.Name:lower() < b.Name:lower()
    end)

    return list
end

local function ensureSelectedTeleportPlayer()
    local list = getTeleportPlayers()

    if #list == 0 then
        selectedTeleportPlayer = nil
        return nil
    end

    for _, player in ipairs(list) do
        if player == selectedTeleportPlayer then
            return selectedTeleportPlayer
        end
    end

    selectedTeleportPlayer = list[1]
    return selectedTeleportPlayer
end

local function cycleTeleportPlayer()
    local list = getTeleportPlayers()

    if #list == 0 then
        selectedTeleportPlayer = nil
        return
    end

    local currentIndex = nil
    for index, player in ipairs(list) do
        if player == selectedTeleportPlayer then
            currentIndex = index
            break
        end
    end

    local nextIndex = currentIndex and currentIndex + 1 or 1
    if nextIndex > #list then
        nextIndex = 1
    end

    selectedTeleportPlayer = list[nextIndex]
end

local function destroyTool()
    if isDestroyed then
        return
    end

    isDestroyed = true
    settings.enabled = false
    settings.autoShoot = false
    settings.fastFire = false
    settings.noBoltAnimation = false
    settings.espCharm = false
    settings.espBox = false
    settings.espHealth = false
    settings.hitboxExpander = false
    settings.flyEnabled = false
    settings.noclipEnabled = false
    settings.infiniteJumpEnabled = false
    isMouseDown = false
    refreshUi = nil

    RunService:UnbindFromRenderStep(renderStepName)
    setCurrentTarget(nil)
    clearHitboxes()

    for _, player in ipairs(Players:GetPlayers()) do
        destroyEsp(player)
        destroyHitbox(player)
    end

    applyNoclip()

    local humanoid = getLocalHumanoid()
    if humanoid then
        humanoid.PlatformStand = false
    end

    for _, connection in ipairs(connections) do
        if connection then
            connection:Disconnect()
        end
    end

    table.clear(connections)

    for player, connection in pairs(playerCharacterConnections) do
        if connection then
            connection:Disconnect()
        end
        playerCharacterConnections[player] = nil
    end

    if screenGui then
        screenGui:Destroy()
        screenGui = nil
    end
end

